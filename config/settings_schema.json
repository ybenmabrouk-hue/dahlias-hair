[
  {
    "name": "theme_info",
    "theme_name": "Dahlia",
    "theme_version": "1.0.0",
    "theme_author": "Dahlia",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image",
        "info": "Falls back to the SVG wordmark (dahlia-logo.svg) if left empty"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width (px)",
        "min": 80,
        "max": 240,
        "step": 4,
        "default": 140
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background",
        "default": "#F5EEE6"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary",
        "default": "#6B1228"
      },
      {
        "type": "color",
        "id": "color_white",
        "label": "Off-white",
        "default": "#FAF6F0"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Gold / Muted",
        "default": "#F0DADA"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#F0DADA"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "heading_font_weight",
        "label": "Heading font weight",
        "options": [
          { "value": "300", "label": "Light (300)" },
          { "value": "400", "label": "Regular (400)" }
        ],
        "default": "300"
      },
      {
        "type": "select",
        "id": "body_font_weight",
        "label": "Body font weight",
        "options": [
          { "value": "400", "label": "Regular (400)" },
          { "value": "500", "label": "Medium (500)" }
        ],
        "default": "400"
      }
    ]
  },
  {
    "name": "Currency",
    "settings": [
      {
        "type": "text",
        "id": "currency_code",
        "label": "Currency code",
        "default": "SAR"
      },
      {
        "type": "text",
        "id": "currency_symbol",
        "label": "Currency symbol",
        "default": "ر.س"
      },
      {
        "type": "select",
        "id": "currency_symbol_position",
        "label": "Symbol position",
        "options": [
          { "value": "before", "label": "Before amount" },
          { "value": "after", "label": "After amount" }
        ],
        "default": "after"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32×32px"
      }
    ]
  }
]
