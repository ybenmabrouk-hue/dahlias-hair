{% comment %}
  Page: /pages/contact
  Hero → two-col (quick contact + form) → reassurance strip
  RTL/LTR via <html dir="">. All text from locale files.
  WhatsApp number and email pulled from global settings.
{% endcomment %}

{%- assign wa_num = settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' -%}
{%- assign wa_msg = 'مرحباً، أريد الاستفسار عن منتجات داليا' | url_encode -%}

<div
  class="pg-con"
  data-section-id="{{ section.id }}"
  data-section-type="page-contact"
>

  {%- comment -%} ── Hero ── {%- endcomment -%}
  <div class="pg-con__hero">
    <div class="pg-con__hero-inner">
      <p class="pg-con__eyebrow">{{ 'pages.contact.eyebrow' | t }}</p>
      <h1 class="pg-con__title">{{ 'pages.contact.title' | t }}</h1>
    </div>
  </div>

  {%- comment -%} ── Two-column body ── {%- endcomment -%}
  <div class="pg-con__body">
    <div class="pg-con__body-inner">

      {%- comment -%} ── Left: quick contact ── {%- endcomment -%}
      <div class="pg-con__left">

        {%- comment -%} WhatsApp card {%- endcomment -%}
        {%- if wa_num != blank -%}
          <div class="pg-con__card pg-con__card--whatsapp">
            <div class="pg-con__card-icon pg-con__card-icon--wa" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.115.549 4.101 1.51 5.833L0 24l6.335-1.481A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.371l-.358-.214-3.72.869.938-3.63-.234-.373A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
              </svg>
            </div>
            <div class="pg-con__card-text">
              <h2 class="pg-con__card-heading">{{ 'pages.contact.whatsapp_heading' | t }}</h2>
              <p class="pg-con__card-subtext">{{ 'pages.contact.whatsapp_subtext' | t }}</p>
            </div>
            <a
              class="pg-con__wa-btn"
              href="https://wa.me/{{ wa_num }}?text={{ wa_msg }}"
              target="_blank"
              rel="noopener noreferrer"
            >
              {{ 'pages.contact.whatsapp_button' | t }}
            </a>
          </div>
        {%- endif -%}

        {%- comment -%} Email card {%- endcomment -%}
        {%- if settings.contact_email != blank -%}
          <div class="pg-con__card pg-con__card--email">
            <div class="pg-con__card-icon pg-con__card-icon--email" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <polyline points="2,4 12,13 22,4"/>
              </svg>
            </div>
            <div class="pg-con__card-text">
              <h2 class="pg-con__card-heading">{{ 'pages.contact.email_heading' | t }}</h2>
              <a class="pg-con__email-address" href="mailto:{{ settings.contact_email }}">
                {{ settings.contact_email }}
              </a>
            </div>
          </div>
        {%- endif -%}

      </div>

      {%- comment -%} ── Right: contact form ── {%- endcomment -%}
      <div class="pg-con__right">
        <div class="pg-con__form-card">
          <h2 class="pg-con__form-heading">{{ 'pages.contact.form_heading' | t }}</h2>

          {%- form 'contact', id: 'ContactPageForm' -%}
            {%- if form.posted_successfully? -%}
              <p class="pg-con__form-success" role="status">
                {{ 'pages.contact.form_success' | t }}
              </p>
            {%- endif -%}

            {%- if form.errors -%}
              <p class="pg-con__form-error" role="alert">
                {{ form.errors | default_errors }}
              </p>
            {%- endif -%}

            <div class="pg-con__fields">

              <div class="pg-con__field">
                <label class="pg-con__label" for="ContactName">
                  {{ 'pages.contact.form_name' | t }}
                </label>
                <input
                  type="text"
                  id="ContactName"
                  name="contact[name]"
                  class="pg-con__input"
                  placeholder="{{ 'pages.contact.form_name_placeholder' | t }}"
                  autocomplete="name"
                  value="{{ form.name }}"
                >
              </div>

              <div class="pg-con__field">
                <label class="pg-con__label" for="ContactEmail">
                  {{ 'pages.contact.form_email' | t }}
                </label>
                <input
                  type="email"
                  id="ContactEmail"
                  name="contact[email]"
                  class="pg-con__input"
                  placeholder="{{ 'pages.contact.form_email_placeholder' | t }}"
                  autocomplete="email"
                  value="{{ form.email }}"
                  required
                >
              </div>

              <div class="pg-con__field">
                <label class="pg-con__label" for="ContactSubject">
                  {{ 'pages.contact.form_subject' | t }}
                </label>
                <select
                  id="ContactSubject"
                  name="contact[subject]"
                  class="pg-con__select"
                >
                  <option value="{{ 'pages.contact.form_subject_order' | t }}">
                    {{ 'pages.contact.form_subject_order' | t }}
                  </option>
                  <option value="{{ 'pages.contact.form_subject_product' | t }}">
                    {{ 'pages.contact.form_subject_product' | t }}
                  </option>
                  <option value="{{ 'pages.contact.form_subject_returns' | t }}">
                    {{ 'pages.contact.form_subject_returns' | t }}
                  </option>
                  <option value="{{ 'pages.contact.form_subject_other' | t }}">
                    {{ 'pages.contact.form_subject_other' | t }}
                  </option>
                </select>
              </div>

              <div class="pg-con__field">
                <label class="pg-con__label" for="ContactMessage">
                  {{ 'pages.contact.form_message' | t }}
                </label>
                <textarea
                  id="ContactMessage"
                  name="contact[body]"
                  class="pg-con__textarea"
                  placeholder="{{ 'pages.contact.form_message_placeholder' | t }}"
                  rows="5"
                >{{ form.body }}</textarea>
              </div>

              <button type="submit" class="btn btn--primary pg-con__submit">
                {{ 'pages.contact.form_submit' | t }}
              </button>

            </div>
          {%- endform -%}

        </div>
      </div>

    </div>
  </div>

  {%- comment -%} ── Reassurance strip ── {%- endcomment -%}
  <div class="pg-con__reassurance">
    <div class="pg-con__reassurance-inner">

      <div class="pg-con__reassurance-item">
        <span class="pg-con__reassurance-icon" aria-hidden="true">
          {%- render 'icon-returns' -%}
        </span>
        <span class="pg-con__reassurance-text">{{ 'pages.contact.reassurance_returns' | t }}</span>
      </div>

      <span class="pg-con__reassurance-sep" aria-hidden="true">✦</span>

      <div class="pg-con__reassurance-item">
        <span class="pg-con__reassurance-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </span>
        <span class="pg-con__reassurance-text">{{ 'pages.contact.reassurance_authentic' | t }}</span>
      </div>

      <span class="pg-con__reassurance-sep" aria-hidden="true">✦</span>

      <div class="pg-con__reassurance-item">
        <span class="pg-con__reassurance-icon" aria-hidden="true">
          {%- render 'icon-shipping' -%}
        </span>
        <span class="pg-con__reassurance-text">{{ 'pages.contact.reassurance_warranty' | t }}</span>
      </div>

    </div>
  </div>

</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": [],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
