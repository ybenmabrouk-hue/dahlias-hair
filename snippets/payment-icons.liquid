{% comment %}
  Payment method icons — inline SVG, brand-accurate logos
  Usage:
    {% render 'payment-icons', context: 'footer' %}   → #FAF6F0, 24px, opacity 0.8
    {% render 'payment-icons', context: 'product' %}  → #2A2018, 18px, opacity 0.5
    {% render 'payment-icons' %}                      → brand colours (default)
{% endcomment %}

{%- assign _ctx = context | default: 'default' -%}

<div class="payment-icons payment-icons--{{ _ctx }}" aria-label="{{ 'footer.payment_methods' | t }}">

  {%- comment -%} ── Mada ──────────────────────────────────────────── {%- endcomment -%}
  <span class="payment-icon" role="img" aria-label="Mada">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" aria-hidden="true" focusable="false">
      <rect width="60" height="38" rx="4" fill="#CC1433"/>
      <text x="30" y="15" text-anchor="middle" font-family="Arial,sans-serif" font-size="9" font-weight="400" fill="white" opacity="0.85">مدى</text>
      <text x="30" y="28" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="700" fill="white" letter-spacing="0.5">mada</text>
    </svg>
  </span>

  {%- comment -%} ── STC Pay ───────────────────────────────────────── {%- endcomment -%}
  <span class="payment-icon" role="img" aria-label="STC Pay">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" aria-hidden="true" focusable="false">
      <rect width="60" height="38" rx="4" fill="#3B0E6E"/>
      <text x="30" y="17" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="800" fill="white" letter-spacing="1">STC</text>
      <text x="30" y="30" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" font-weight="400" fill="#C4A0FF" letter-spacing="0.5">pay</text>
    </svg>
  </span>

  {%- comment -%} ── Apple Pay ─────────────────────────────────────── {%- endcomment -%}
  <span class="payment-icon" role="img" aria-label="Apple Pay">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" aria-hidden="true" focusable="false">
      <rect width="60" height="38" rx="4" fill="#000"/>
      <!-- Simplified Apple mark -->
      <path d="M22.5 10.5c.9-1.1 1.5-2.6 1.3-4.1-1.3.1-2.8.9-3.7 2-.8 1-1.5 2.6-1.2 4.1 1.3.1 2.7-.7 3.6-2zm.7 1.8c-2-.1-3.7 1.1-4.7 1.1-1 0-2.4-1-3.9-1-2 0-3.8 1.2-4.8 3-2.1 3.6.6 8.9 1.5 11.8.9 1.5 2.1 3.2 3.6 3.2 1.4-.1 2-.9 3.7-.9 1.7 0 2.2.9 3.7.9 1.5 0 2.6-1.6 3.5-3.1.5-.9.8-1.7 1.1-2.7-2.9-1.1-3.4-5.3-.6-7-1-1.5-2.5-2.8-3.1-5.3z" fill="white"/>
      <text x="38" y="24" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" font-weight="500" fill="white" letter-spacing="0.3">Pay</text>
    </svg>
  </span>

  {%- comment -%} ── Tamara ────────────────────────────────────────── {%- endcomment -%}
  <span class="payment-icon" role="img" aria-label="Tamara">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" aria-hidden="true" focusable="false">
      <rect width="60" height="38" rx="4" fill="#01C9B0"/>
      <text x="30" y="24" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" font-weight="700" fill="white" letter-spacing="0.5">tamara</text>
    </svg>
  </span>

  {%- comment -%} ── Visa ──────────────────────────────────────────── {%- endcomment -%}
  <span class="payment-icon" role="img" aria-label="Visa">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" aria-hidden="true" focusable="false">
      <rect width="60" height="38" rx="4" fill="#1A1F71"/>
      <text x="30" y="26" text-anchor="middle" font-family="Arial,sans-serif" font-size="18" font-weight="700" font-style="italic" fill="white" letter-spacing="1">VISA</text>
    </svg>
  </span>

  {%- comment -%} ── Mastercard ────────────────────────────────────── {%- endcomment -%}
  <span class="payment-icon" role="img" aria-label="Mastercard">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" aria-hidden="true" focusable="false">
      <rect width="60" height="38" rx="4" fill="#F7F7F7"/>
      <circle cx="23" cy="19" r="11" fill="#EB001B"/>
      <circle cx="37" cy="19" r="11" fill="#F79E1B" opacity="0.92"/>
      <!-- Overlap wedge -->
      <path d="M30 10.2a11 11 0 0 1 0 17.6A11 11 0 0 1 30 10.2z" fill="#FF5F00"/>
    </svg>
  </span>

</div>
