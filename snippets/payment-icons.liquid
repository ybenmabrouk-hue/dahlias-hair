{% comment %}
  Payment method icons — inline SVG badges
  Mada · STC Pay · Apple Pay · Tamara · Visa · Mastercard
{% endcomment %}

{%- comment -%} Mada {%- endcomment -%}
<span class="payment-icon" title="Mada">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 32" width="52" height="32" role="img" aria-label="Mada">
    <rect width="52" height="32" rx="4" fill="#CC1433"/>
    <text x="26" y="21" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" font-weight="700" fill="white" letter-spacing="0.5">mada</text>
  </svg>
</span>

{%- comment -%} STC Pay {%- endcomment -%}
<span class="payment-icon" title="STC Pay">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 32" width="52" height="32" role="img" aria-label="STC Pay">
    <rect width="52" height="32" rx="4" fill="#3B0E6E"/>
    <text x="26" y="14" text-anchor="middle" font-family="Arial, sans-serif" font-size="8.5" font-weight="700" fill="white" letter-spacing="0.5">STC</text>
    <text x="26" y="25" text-anchor="middle" font-family="Arial, sans-serif" font-size="8.5" font-weight="400" fill="#C8A0FF" letter-spacing="0.5">pay</text>
  </svg>
</span>

{%- comment -%} Apple Pay {%- endcomment -%}
<span class="payment-icon" title="Apple Pay">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 32" width="52" height="32" role="img" aria-label="Apple Pay">
    <rect width="52" height="32" rx="4" fill="#000000"/>
    <text x="28" y="21" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" font-weight="500" fill="white" letter-spacing="0.3"> Pay</text>
    <!-- Simplified apple shape -->
    <path d="M14.5 12.2c.7-.9 1.2-2.1 1.1-3.2-1 .1-2.3.7-3 1.6-.6.8-1.2 2-.9 3.2 1.1.1 2.2-.5 2.8-1.6zm.7 1.2c-1.6-.1-3 .9-3.7.9-.8 0-1.9-.9-3.2-.8-1.6.1-3.1 1-4 2.5-1.7 3 .5 7.4 1.2 9.8.8 1.2 1.7 2.4 2.9 2.4 1.1 0 1.5-.7 2.9-.7 1.4 0 1.8.7 2.9.7 1.2 0 2.2-1.3 3-2.5.4-.7.7-1.4.9-2.2-2.4-.9-2.8-4.4-.5-5.8-.8-1.2-2.1-2.3-2.4-4.3z" fill="white" transform="scale(0.6) translate(8, 3)"/>
  </svg>
</span>

{%- comment -%} Tamara {%- endcomment -%}
<span class="payment-icon" title="Tamara">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 32" width="52" height="32" role="img" aria-label="Tamara">
    <rect width="52" height="32" rx="4" fill="#01C9B0"/>
    <text x="26" y="21" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" font-weight="700" fill="white" letter-spacing="0.5">tamara</text>
  </svg>
</span>

{%- comment -%} Visa {%- endcomment -%}
<span class="payment-icon" title="Visa">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 32" width="52" height="32" role="img" aria-label="Visa">
    <rect width="52" height="32" rx="4" fill="#1A1F71"/>
    <text x="26" y="22" text-anchor="middle" font-family="Arial, sans-serif" font-size="16" font-weight="700" font-style="italic" fill="white" letter-spacing="1">VISA</text>
  </svg>
</span>

{%- comment -%} Mastercard {%- endcomment -%}
<span class="payment-icon" title="Mastercard">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 32" width="52" height="32" role="img" aria-label="Mastercard">
    <rect width="52" height="32" rx="4" fill="#F7F7F7"/>
    <circle cx="20" cy="16" r="9" fill="#EB001B"/>
    <circle cx="32" cy="16" r="9" fill="#F79E1B" opacity="0.9"/>
    <!-- Overlap blend -->
    <path d="M26 8.6a9 9 0 010 14.8A9 9 0 0126 8.6z" fill="#FF5F00"/>
  </svg>
</span>
