{% comment %}
  Payment note — KSA reassurance line
  Render on cart page / cart drawer to reassure customers before checkout.
  Usage: {% render 'payment-note' %}
{% endcomment %}

<p class="payment-note">
  <span class="payment-note__icons" aria-hidden="true">
    <!-- Mada micro-badge -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 22" width="36" height="22" aria-hidden="true" focusable="false">
      <rect width="36" height="22" rx="3" fill="#CC1433"/>
      <text x="18" y="15" text-anchor="middle" font-family="Arial,sans-serif" font-size="8" font-weight="700" fill="white">mada</text>
    </svg>
    <!-- STC Pay micro-badge -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 22" width="36" height="22" aria-hidden="true" focusable="false">
      <rect width="36" height="22" rx="3" fill="#3B0E6E"/>
      <text x="18" y="10" text-anchor="middle" font-family="Arial,sans-serif" font-size="7" font-weight="800" fill="white">STC</text>
      <text x="18" y="18" text-anchor="middle" font-family="Arial,sans-serif" font-size="6" fill="#C4A0FF">pay</text>
    </svg>
  </span>
  {{ 'payment_note' | t }}
</p>
